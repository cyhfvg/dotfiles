# git bash bashrc

export LANG="zh_CN.UTF-8"
export LC_ALL="zh_CN.UTF-8"
export OUTPUT_CHARSET="utf-8"

#set -o vi
#bind -x '"\C-l": clear;'

# escap windows terminal starting directory with prompt
PROMPT_COMMAND=${PROMPT_COMMAND:+"$PROMPT_COMMAND; "}'printf "\e]9;9;%s\e\\" "`cygpath -w "$PWD"`"'


# bash proxy {{{1
proxy_on() {
    local proxy="http://127.0.0.1:7893"
    local no_proxy="localhost,127.0.0.1,::1"

    export HTTP_PROXY="$proxy"
    export HTTPS_PROXY="$proxy"
    export ALL_PROXY="$proxy"
    export NO_PROXY="$no_proxy"

    echo "[proxy_on] Proxy enabled: $proxy"
    echo "HTTP_PROXY=$HTTP_PROXY"
    echo "HTTPS_PROXY=$HTTPS_PROXY"
    echo "ALL_PROXY=$ALL_PROXY"
    echo "NO_PROXY=$NO_PROXY"
}

proxy_off() {
    unset HTTP_PROXY
    unset HTTPS_PROXY
    unset ALL_PROXY
    unset NO_PROXY

    echo "[proxy_off] Proxy disabled."
}

proxy_status() {
    echo "HTTP_PROXY=${HTTP_PROXY}"
    echo "HTTPS_PROXY=${HTTPS_PROXY}"
    echo "ALL_PROXY=${ALL_PROXY}"
    echo "NO_PROXY=${NO_PROXY}"
}
# }}}
